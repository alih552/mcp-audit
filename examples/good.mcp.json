      "headers": { "Authorization": "Bearer ${GITHUB_MCP_TOKEN}" }
    },
    "filesystem": {
      "command": "npx",
      "args": ["@modelcontextprotocol/server-filesystem@1.4.2", "./project-workspace"]
    }
  }
}
